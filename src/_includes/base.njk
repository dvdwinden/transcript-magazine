<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRANSCRIPT / SEASONAL LITERARY MAGAZINE</title>
    <meta name="description" content="{{ description or 'TRANSCRIPT is a seasonal magazine, featuring literary essays, short stories, poetry, and everything in-between.' }}">
    <link rel="icon" href="/assets/favicon.png">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="font-serif">
    <main role="main">
        {{ content | safe }}
    </main>
    <div class="lightbox" id="lightbox">
        <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
        <div class="lightbox-inner"></div>
        <div class="lightbox-caption"></div>
    </div>
    <script>
        const lightbox = document.getElementById('lightbox');
        const inner = lightbox.querySelector('.lightbox-inner');
        const caption = lightbox.querySelector('.lightbox-caption');
        const closeBtn = lightbox.querySelector('.lightbox-close');
        const clickables = document.querySelectorAll('.photo-placeholder, img');

        function closeLightbox() {
            lightbox.classList.remove('active');
            inner.innerHTML = '';
            caption.innerHTML = '';
        }

        clickables.forEach(el => {
            if (!lightbox.contains(el)) {
                el.style.cursor = 'pointer';
                el.addEventListener('click', (e) => {
                    e.stopPropagation();
                    inner.innerHTML = '';
                    caption.innerHTML = '';
                    const clone = el.cloneNode(true);
                    // Ensure reasonable size inside lightbox
                    clone.style.width = '';
                    clone.style.height = '';
                    inner.appendChild(clone);
                    
                    // Add caption if image has alt text
                    const altText = el.alt || el.querySelector('img')?.alt;
                    if (altText) {
                        caption.textContent = altText;
                    }
                    
                    lightbox.classList.add('active');
                });
            }
        });

        lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox) {
                closeLightbox();
            }
        });

        closeBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            closeLightbox();
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && lightbox.classList.contains('active')) {
                closeLightbox();
            }
        });

        // Image loop — show each frame for 0.5s
        const slideshow = document.querySelector('.slideshow');
        if (slideshow) {
            const frames = Array.from(slideshow.querySelectorAll('picture'));
            if (frames.length) {
                // Decode every frame up front so there's no white flash on first pass
                slideshow.querySelectorAll('img').forEach(img => {
                    img.loading = 'eager';
                    if (img.decode) { img.decode().catch(() => {}); }
                });

                const shuffle = (a) => {
                    for (let i = a.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [a[i], a[j]] = [a[j], a[i]];
                    }
                    return a;
                };

                // Build a play order that spreads each group evenly across the
                // whole sequence, so same-issue/same-shoot frames never cluster.
                const buildOrder = () => {
                    const groups = {};
                    frames.forEach((f) => {
                        const img = f.querySelector('img');
                        const src = (img && (img.currentSrc || img.src)) || '';
                        const m = src.match(/issue-(one|two|three)/);
                        const key = (m ? m[1] : 'other') + (/event/.test(src) ? '-event' : '');
                        (groups[key] = groups[key] || []).push(f);
                    });
                    // Give each frame a fractional slot evenly spaced within its
                    // group (plus jitter), then sort — large groups get spread out
                    // across the full run instead of clumping at the tail.
                    const items = [];
                    Object.values(groups).forEach((g) => {
                        shuffle(g);
                        g.forEach((f, k) => items.push({ f, pos: (k + Math.random()) / g.length }));
                    });
                    items.sort((a, b) => a.pos - b.pos);
                    return items.map((x) => x.f);
                };

                let order = buildOrder();
                let i = 0;
                order[0].classList.add('active');
                setInterval(() => {
                    order[i].classList.remove('active');
                    i++;
                    if (i >= order.length) { i = 0; order = buildOrder(); } // re-mix each loop
                    order[i].classList.add('active');
                }, 500);
            }
        }

        // Sticky header logic — fade the logo in once scrolled past the opening logo
        const stickyHeader = document.getElementById('sticky-header');
        const logoHeader = document.querySelector('.logo-header');

        function updateStickyHeader() {
            const logoHeaderBottom = logoHeader ? logoHeader.offsetHeight : 0;
            if (window.scrollY > logoHeaderBottom - 100) {
                stickyHeader.classList.add('visible');
            } else {
                stickyHeader.classList.remove('visible');
            }
        }

        window.addEventListener('scroll', updateStickyHeader);
        window.addEventListener('load', updateStickyHeader);
    </script>
</body>
</html>
