{% set siteUrl = 'https://transcriptmag.store' %}
{% set siteTitle = 'TRANSCRIPT / SEASONAL LITERARY MAGAZINE' %}
{% set siteDesc = description or 'TRANSCRIPT is a seasonal magazine, featuring literary essays, short stories, poetry, and everything in-between.' %}
{% set siteImage = siteUrl + '/assets/og-image.jpg' %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ siteTitle }}</title>
    <meta name="description" content="{{ siteDesc }}">
    <link rel="canonical" href="{{ siteUrl }}/">
    <meta name="theme-color" content="#ffffff">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="TRANSCRIPT">
    <meta property="og:title" content="{{ siteTitle }}">
    <meta property="og:description" content="{{ siteDesc }}">
    <meta property="og:url" content="{{ siteUrl }}/">
    <meta property="og:image" content="{{ siteImage }}">
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="TRANSCRIPT Magazine">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ siteTitle }}">
    <meta name="twitter:description" content="{{ siteDesc }}">
    <meta name="twitter:image" content="{{ siteImage }}">

    <link rel="icon" href="/assets/favicon.png">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="font-serif">
    <main role="main">
        {{ content | safe }}
    </main>
    <script>
        // Image loop — show each frame for 0.5s
        const slideshow = document.querySelector('.slideshow');
        if (slideshow) {
            const frames = Array.from(slideshow.querySelectorAll('picture'));
            if (frames.length) {
                // Decode every frame up front so there's no white flash on first pass
                slideshow.querySelectorAll('img').forEach(img => {
                    img.loading = 'eager';
                    if (img.decode) { img.decode().catch(() => {}); }
                });

                // Give each frame a slightly different size so the loop feels
                // more random / less uniform. Images run a bit larger on mobile.
                const mobile = window.matchMedia('(max-width: 600px)').matches;
                const widthBase = mobile ? 82 : 65;
                const heightBase = mobile ? 60 : 62;
                frames.forEach((f) => {
                    const img = f.querySelector('img');
                    if (img) {
                        const scale = 0.6 + Math.random() * 0.4; // 0.6–1.0 of the cap
                        img.style.maxWidth = (widthBase * scale).toFixed(1) + '%';
                        img.style.maxHeight = (heightBase * scale).toFixed(1) + 'svh';
                    }
                });

                const shuffle = (a) => {
                    for (let i = a.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [a[i], a[j]] = [a[j], a[i]];
                    }
                    return a;
                };

                // Build a play order that spreads each group evenly across the
                // whole sequence, so same-issue/same-shoot frames never cluster.
                const buildOrder = () => {
                    const groups = {};
                    frames.forEach((f) => {
                        const img = f.querySelector('img');
                        const src = (img && (img.currentSrc || img.src)) || '';
                        const m = src.match(/issue-(one|two|three)/);
                        const key = (m ? m[1] : 'other') + (/event/.test(src) ? '-event' : '');
                        (groups[key] = groups[key] || []).push(f);
                    });
                    // Give each frame a fractional slot evenly spaced within its
                    // group (plus jitter), then sort — large groups get spread out
                    // across the full run instead of clumping at the tail.
                    const items = [];
                    Object.values(groups).forEach((g) => {
                        shuffle(g);
                        g.forEach((f, k) => items.push({ f, pos: (k + Math.random()) / g.length }));
                    });
                    items.sort((a, b) => a.pos - b.pos);
                    return items.map((x) => x.f);
                };

                let order = buildOrder();
                let i = 0;
                order[0].classList.add('active');

                const advance = () => {
                    order[i].classList.remove('active');
                    i++;
                    if (i >= order.length) { i = 0; order = buildOrder(); } // re-mix each loop
                    order[i].classList.add('active');
                };

                // Only run the loop while it's on-screen and the tab is visible
                let timer = null;
                let onScreen = false;
                const startLoop = () => { if (!timer && onScreen && !document.hidden) timer = setInterval(advance, 500); };
                const stopLoop = () => { if (timer) { clearInterval(timer); timer = null; } };

                if ('IntersectionObserver' in window) {
                    new IntersectionObserver((entries) => {
                        onScreen = entries[0].isIntersecting;
                        if (onScreen) startLoop(); else stopLoop();
                    }, { threshold: 0 }).observe(slideshow);
                } else {
                    onScreen = true;
                    startLoop();
                }
                document.addEventListener('visibilitychange', () => {
                    if (document.hidden) stopLoop(); else startLoop();
                });
            }
        }

        // Subtle blur + fade as each section scrolls into view (and back out,
        // reversing when scrolling up). On the black stats section we blur only
        // the text inside, not the whole section.
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!prefersReducedMotion && 'IntersectionObserver' in window) {
            const reveals = document.querySelectorAll('.logo-header img, .subtitle, .postcard, .description-inner, .bookmark-section picture');
            reveals.forEach(el => el.classList.add('reveal'));
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    entry.target.classList.toggle('is-visible', entry.isIntersecting);
                });
            }, { rootMargin: '0px 0px -20% 0px', threshold: 0 });
            reveals.forEach(el => revealObserver.observe(el));
        }
    </script>
</body>
</html>
