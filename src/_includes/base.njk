<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRANSCRIPT / SEASONAL LITERARY MAGAZINE</title>
    <meta name="description" content="{{ description or 'TRANSCRIPT is a seasonal magazine, featuring literary essays, short stories, poetry, and everything in-between.' }}">
    <link rel="icon" href="/assets/favicon.png">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="font-serif">
    <main role="main">
        {{ content | safe }}
    </main>
    <script>
        // Image loop — show each frame for 0.5s
        const slideshow = document.querySelector('.slideshow');
        if (slideshow) {
            const frames = Array.from(slideshow.querySelectorAll('picture'));
            if (frames.length) {
                // Decode every frame up front so there's no white flash on first pass
                slideshow.querySelectorAll('img').forEach(img => {
                    img.loading = 'eager';
                    if (img.decode) { img.decode().catch(() => {}); }
                });

                // Give each frame a slightly different size so the loop feels
                // more random / less uniform.
                frames.forEach((f) => {
                    const img = f.querySelector('img');
                    if (img) {
                        const scale = 0.6 + Math.random() * 0.4; // 0.6–1.0 of the cap
                        img.style.maxWidth = (65 * scale).toFixed(1) + '%';
                        img.style.maxHeight = (55 * scale).toFixed(1) + 'vh';
                    }
                });

                const shuffle = (a) => {
                    for (let i = a.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [a[i], a[j]] = [a[j], a[i]];
                    }
                    return a;
                };

                // Build a play order that spreads each group evenly across the
                // whole sequence, so same-issue/same-shoot frames never cluster.
                const buildOrder = () => {
                    const groups = {};
                    frames.forEach((f) => {
                        const img = f.querySelector('img');
                        const src = (img && (img.currentSrc || img.src)) || '';
                        const m = src.match(/issue-(one|two|three)/);
                        const key = (m ? m[1] : 'other') + (/event/.test(src) ? '-event' : '');
                        (groups[key] = groups[key] || []).push(f);
                    });
                    // Give each frame a fractional slot evenly spaced within its
                    // group (plus jitter), then sort — large groups get spread out
                    // across the full run instead of clumping at the tail.
                    const items = [];
                    Object.values(groups).forEach((g) => {
                        shuffle(g);
                        g.forEach((f, k) => items.push({ f, pos: (k + Math.random()) / g.length }));
                    });
                    items.sort((a, b) => a.pos - b.pos);
                    return items.map((x) => x.f);
                };

                let order = buildOrder();
                let i = 0;
                order[0].classList.add('active');
                setInterval(() => {
                    order[i].classList.remove('active');
                    i++;
                    if (i >= order.length) { i = 0; order = buildOrder(); } // re-mix each loop
                    order[i].classList.add('active');
                }, 500);
            }
        }

        // Subtle blur + fade as each section scrolls into view (and back out,
        // reversing when scrolling up). On the black stats section we blur only
        // the text inside, not the whole section.
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!prefersReducedMotion && 'IntersectionObserver' in window) {
            const reveals = document.querySelectorAll('.logo-header img, .subtitle, .postcard, .description-inner, .bookmark-section picture');
            reveals.forEach(el => el.classList.add('reveal'));
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    entry.target.classList.toggle('is-visible', entry.isIntersecting);
                });
            }, { threshold: 0.15 });
            reveals.forEach(el => revealObserver.observe(el));
        }
    </script>
</body>
</html>
